# Local secrets — copy to .env.local and fill in real values.
# .env.local is git-ignored; never commit real tokens.
#
# Usage:
#   node --env-file=.env.local bin/vibe-discord-import.mjs --dry-run

# Discord bot token (Bot → Reset Token in https://discord.com/developers/applications)
# Required permissions: Read Message History + View Channel
DISCORD_BOT_TOKEN=

# Discord forum / thread / text channel ID to scrape
DISCORD_CHANNEL_ID=

# GitHub repo for issue dedup (optional, default: vibeideteam/vibeide)
# GITHUB_REPO=owner/repo

# GitHub token for private repos or higher rate-limit (optional)
# GITHUB_TOKEN=
