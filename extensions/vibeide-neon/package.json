{
	"name": "vibeide-neon",
	"displayName": "%displayName%",
	"description": "%description%",
	"version": "2.3.1",
	"publisher": "vibeide",
	"license": "MIT",
	"engines": {
		"vscode": "^1.118.0"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./extension.js",
	"extensionKind": ["ui"],
	"categories": ["Themes"],
	"contributes": {
		"configurationDefaults": {
			"workbench.colorTheme": "vibe-neon",
			"workbench.preferredDarkColorTheme": "vibe-neon"
		},
		"themes": [
			{
				"label": "%theme.vibeNeon.label%",
				"id": "vibe-neon",
				"uiTheme": "vs-dark",
				"path": "./themes/vibe-neon.json"
			},
			{
				"label": "%theme.vibeNeonNoGlow.label%",
				"id": "vibe-neon-noglow",
				"uiTheme": "vs-dark",
				"path": "./themes/vibe-neon-noglow.json"
			}
		],
		"commands": [
			{
				"command": "vibeide.trustScore.toggle",
				"title": "%command.trustScore.toggle.title%"
			},
			{
				"command": "vibeide.trustScore.setManual",
				"title": "%command.trustScore.setManual.title%"
			},
			{
				"command": "vibeide.trustScore.setSupervised",
				"title": "%command.trustScore.setSupervised.title%"
			},
			{
				"command": "vibeide.trustScore.setAuto",
				"title": "%command.trustScore.setAuto.title%"
			},
			{
				"command": "vibeide.tokenBudget.reset",
				"title": "%command.tokenBudget.reset.title%"
			},
			{
				"command": "vibeide.doctor.run",
				"title": "%command.doctor.run.title%"
			},
			{
				"command": "vibeide.audit.export",
				"title": "%command.audit.export.title%"
			},
			{
				"command": "vibeide.audit.deleteAll",
				"title": "%command.audit.deleteAll.title%"
			},
			{
				"command": "vibeide.transparency.show",
				"title": "%command.transparency.show.title%"
			}
		],
		"keybindings": [
			{
				"command": "vibeide.trustScore.toggle",
				"key": "ctrl+shift+t",
				"mac": "cmd+shift+t"
			},
			{
				"command": "vibeide.explainLine",
				"key": "ctrl+.",
				"mac": "cmd+."
			},
			{
				"command": "vibeide.agent.pauseAndExplain",
				"key": "ctrl+shift+p",
				"when": "vibeide.agentRunning",
				"mac": "cmd+shift+p"
			},
			{
				"command": "vibeide.freezeCode",
				"key": "ctrl+shift+f",
				"when": "editorHasSelection",
				"mac": "cmd+shift+f"
			}
		],
		"configuration": {
			"title": "%configuration.title%",
			"properties": {
				"vibeide.trustScore.level": {
					"type": "string",
					"enum": ["manual", "supervised", "auto"],
					"default": "manual",
					"enumDescriptions": [
						"%configuration.trustScore.level.manual.description%",
						"%configuration.trustScore.level.supervised.description%",
						"%configuration.trustScore.level.auto.description%"
					],
					"description": "%configuration.trustScore.level.description%"
				},
				"vibeide.skills.workspaceDiscoveryHint": {
					"type": "boolean",
					"default": true,
					"description": "%configuration.skills.workspaceDiscoveryHint.description%"
				}
			}
		}
	},
	"_upstream": {
		"source": "https://github.com/robb0wen/synthwave-vscode",
		"version": "0.1.20",
		"license": "MIT",
		"syncedAt": "2026-05-03"
	}
}
