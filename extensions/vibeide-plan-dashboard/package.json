{
	"name": "vibeide-plan-dashboard",
	"displayName": "%displayName%",
	"description": "%description%",
	"version": "1.0.0",
	"publisher": "vibeide",
	"license": "MIT",
	"engines": {
		"vscode": "^1.118.0"
	},
	"extensionKind": ["ui", "workspace"],
	"activationEvents": ["onCustomEditor:vibeide.planDashboard"],
	"main": "./extension.js",
	"l10n": "./l10n",
	"contributes": {
		"customEditors": [
			{
				"viewType": "vibeide.planDashboard",
				"displayName": "%customEditor.planDashboard.displayName%",
				"priority": "default",
				"selector": [
					{
						"filenamePattern": "**/.vibe/plans/**/*.plan.md"
					}
				]
			}
		],
		"commands": [
			{
				"command": "vibeide.planDashboard.openAsText",
				"title": "%command.planDashboard.openAsText.title%",
				"icon": "$(code)"
			}
		],
		"menus": {
			"editor/title": [
				{
					"command": "vibeide.planDashboard.openAsText",
					"when": "activeCustomEditorId == 'vibeide.planDashboard'",
					"group": "navigation@9"
				}
			]
		}
	}
}
