{
  "version": "1.1.0",
  "updatedAt": "2026-05-06",
  "meta": {
    "description": "VibeIDE Models Registry — training data policy and capabilities per model. Shown in the status bar (train ? indicator). Only models with a known policy need to be listed; unlisted models show 'train ?' in the UI.",
    "howToUpdate": [
      "1. Check the provider's privacy/data-use policy page (see policySourcesByProvider below).",
      "2. Add or update the model entry in the 'models' array.",
      "3. Set 'checkedAt' to today's date (YYYY-MM-DD).",
      "4. Update the top-level 'updatedAt' field.",
      "5. Open a PR — no code changes needed, just this file."
    ],
    "trainingPolicyValues": {
      "none":               "Provider explicitly states API data is NOT used for model training.",
      "opt-in":             "Training on your data requires explicit opt-in (off by default).",
      "opt-out-available":  "Provider may train on data by default; an opt-out mechanism exists.",
      "always":             "Provider trains on prompts under default terms; no opt-out (typical for free tiers)."
    },
    "policySourcesByProvider": {
      "anthropic":    "https://www.anthropic.com/privacy — API usage is not used to train models",
      "openai":       "https://openai.com/policies/api-data-usage-policies — API data not used for training by default since Mar 2023",
      "gemini":       "https://ai.google.dev/gemini-api/terms — API data not used to train Google models",
      "deepseek":     "https://www.deepseek.com/privacy — API data not used for model training",
      "mistral":      "https://mistral.ai/terms — API inputs/outputs not used for training",
      "groq":         "https://groq.com/privacy-policy — prompts not used for model training",
      "xai":          "https://x.ai/legal/privacy-policy — review periodically, policy evolving",
      "openrouter":   "https://openrouter.ai/privacy — OpenRouter itself doesn't train; underlying provider policy applies",
      "openCodeZen":  "https://opencode.ai/docs/zen — free-tier models may be used for training",
      "openCode":     "https://opencode.ai/docs/go — Go subscription; check current terms",
      "pollinations": "https://pollinations.ai — free service, prompts may be used for improvement",
      "azure":        "https://learn.microsoft.com/en-us/legal/cognitive-services/openai/data-privacy — not used by default",
      "vertex":       "https://cloud.google.com/vertex-ai/generative-ai/docs/data-governance — not used for training",
      "ollama":       "Local — no data leaves the machine",
      "vLLM":         "Local — no data leaves the machine",
      "lmStudio":     "Local — no data leaves the machine"
    }
  },
